# Production Environment Variables for Docker Compose
# Copy this to .env and update with your actual values

# Backend Configuration
JWT_SECRET= Admin Backend Secret Key
BACKEND_PORT=5011
MONGODB_URI= MongoDB URI
NODE_ENV=production
AUTH_SERVER_URL=http://host.docker.internal:5050
TZ=Asia/Kolkata

# Frontend Configuration
VITE_ADMIN_LOGIN_URL=http://localhost:3000/admin/login
VITE_APP_API_PREFIX=http://localhost:5011
FRONTEND_PORT=5012

# Nginx Proxy Configuration (for production deployment)
PROXY_PORT=80
PROXY_SSL_PORT=443

# Database Configuration (if using local MongoDB)
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=your_secure_password
# MONGO_INITDB_DATABASE=vp_esr_booking